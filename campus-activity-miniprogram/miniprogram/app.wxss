/**app.wxss**/
page {
  --primary: #4096FF;
  --primary-light: #E8F2FF;
  --success: #52C41A;
  --danger: #E54545;
  --warning: #FF9500;
  --bg: #f7fbff;
  --card-bg: #FFFFFF;
  --text-primary: #1D2129;
  --text-secondary: #86909C;
  --text-light: #C9CDD4;
  --border: #F0F1F3;
  --shadow: 0 2rpx 20rpx rgba(64, 150, 255, 0.08);
  
  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.container {
  padding: 15rpx 15rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

/* 通用卡片样式 */
.card {
  background: var(--card-bg);
  border-radius: 20rpx;
  box-shadow: var(--shadow);
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* 通用按钮 */
.btn-primary {
  background: var(--primary) !important;
  color: #fff !important;
  border-radius: 12rpx !important;
  font-size: 30rpx !important;
  font-weight: 500;
}

.btn-danger {
  background: var(--danger) !important;
  color: #fff !important;
  border-radius: 12rpx !important;
  font-size: 28rpx !important;
}

.btn-outline {
  border: 2rpx solid var(--primary) !important;
  color: var(--primary) !important;
  background: transparent !important;
  border-radius: 12rpx !important;
  font-size: 28rpx !important;
}

.btn-small {
  padding: 8rpx 24rpx !important;
  font-size: 24rpx !important;
  border-radius: 8rpx !important;
}

/* 状态标签 */
.status-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-upcoming {
  background: #E8F2FF;
  color: #4096FF;
}

.status-ongoing {
  background: #E8F8EE;
  color: #52C41A;
}

.status-ended {
  background: #F5F5F5;
  color: #C9CDD4;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-light);
}

.empty-state .empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state .empty-text {
  font-size: 28rpx;
}

/* 加载状态 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-light);
  font-size: 24rpx;
}