/* pages/detail/detail.wxss - 活动详情页样式 */

.detail-header {
  padding: 20rpx 0;
  text-align: center;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-top: 16rpx;
  line-height: 1.4;
}

/* 信息卡片 */
.info-card,
.desc-card,
.progress-card {
  padding: 28rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  margin-left: 20rpx;
}

/* 活动介绍 */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.desc-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 报名进度 */
.progress-wrap {
  padding: 10rpx 0;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90D9, #6BB5FF);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 24rpx;
  color: #999;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  justify-content: center;
}

.btn-signup {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 44rpx;
  font-weight: 600;
}

.btn-disabled {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #ddd !important;
  color: #999 !important;
  border-radius: 44rpx;
  font-size: 32rpx;
}

.btn-registered {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07C160 !important;
  color: #fff !important;
  border-radius: 44rpx;
  font-size: 32rpx;
  opacity: 0.8;
}

/* 底部留白，防止被底部栏遮挡 */
.container {
  padding-bottom: 140rpx;
}

/* 加载状态 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: #999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #eee;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
