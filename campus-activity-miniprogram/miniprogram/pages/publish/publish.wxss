/* pages/publish/publish.wxss */

/* ========== 自定义导航栏 ========== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: linear-gradient(135deg, #69B1FF 0%, #4096FF 50%, #1677FF 100%);
  box-shadow: 0 4rpx 20rpx rgba(64, 150, 255, 0.25);
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.back-icon {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 700;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  flex: 1;
  text-align: center;
  margin-right: 80rpx;
}

/* ========== 页面主体 ========== */
.page-body {
  background: #F0F4FA;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.form-scroll {
  flex: 1;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

/* ========== 表单组 ========== */
.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #1D2129;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.label-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
  opacity: 0.65;
  flex-shrink: 0;
}

.required {
  color: #E53E3E;
  margin-right: 4rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 84rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1D2129;
  box-sizing: border-box;
  transition: all 0.2s;
}

.form-input:focus {
  box-shadow: 0 0 0 2rpx #4096FF inset;
}

/* 选择器 */
.form-picker {
  width: 100%;
  height: 84rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #1D2129;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.picker-placeholder {
  color: #B0B8C8;
}

/* 时间行 */
.time-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.time-row .form-picker {
  flex: 1;
}

.time-sep {
  font-size: 26rpx;
  color: #86909C;
  flex-shrink: 0;
}

/* 多行文本 */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #1D2129;
  box-sizing: border-box;
  transition: all 0.2s;
}

.form-textarea:focus {
  box-shadow: 0 0 0 2rpx #4096FF inset;
}

/* 上传区域 */
.upload-wrap {
  width: 100%;
  height: 320rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 2rpx dashed #D0D5DD;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 60rpx;
  color: #B0B8C8;
  line-height: 1;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 26rpx;
  color: #86909C;
}

.banner-preview {
  width: 100%;
  height: 100%;
  display: block;
}

.upload-tip {
  display: block;
  font-size: 22rpx;
  color: #86909C;
  margin-top: 10rpx;
}

/* ========== 底部按钮 ========== */
.bottom-btns {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #EEF0F4;
}

.btn-cancel {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  background: #FFFFFF;
  border: 2rpx solid #4096FF;
  border-radius: 42rpx;
  color: #4096FF;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-submit {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 84rpx;
  background: #4096FF;
  border-radius: 42rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

.btn-submit:active {
  background: #1677FF;
}

/* ========== 隐藏裁剪画布（兜底方案） ========== */
.crop-canvas {
  position: fixed;
  left: -9999rpx;
  top: -9999rpx;
  width: 750rpx;
  height: 422rpx;
}
