/* pages/index/index.wxss - 首页活动列表样式 */

/* ========== 自定义导航栏 ========== */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 999;
  background: linear-gradient(135deg, #7CB8FF 0%, #50A0FF 50%, #1677FF 100%);
  box-shadow: 0 3rpx 6rpx rgba(64, 150, 255, 0.12);
  border-bottom-left-radius: 24rpx;
  border-bottom-right-radius: 24rpx;
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 0 30rpx;
}

.nav-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.nav-title-group {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.2;
}

.nav-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 2rpx;
}

/* ========== 页面主体 ========== */
.page-body {
  background: #f7fbff;
  min-height: 100vh;
  padding: 8rpx 15rpx 0;
  box-sizing: border-box;
}

/* ========== 空状态 ========== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 180rpx;
}

.empty-img {
  width: 360rpx;
  height: 360rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-light);
  text-align: center;
}

/* ========== 活动卡片 ========== */
.activity-card {
  margin: 0 0 24rpx 0;
  padding: 0;
  border-radius: 24rpx;
  overflow: hidden;
  background: #FFFFFF;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.activity-card:active {
  transform: scale(0.985);
  box-shadow: 0 4rpx 30rpx rgba(0, 0, 0, 0.1);
}

/* 卡片 Banner 区 */
.card-banner {
  position: relative;
  width: 100%;
  overflow: hidden;
  background: #E8F2FF;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
}

.banner-img {
  width: 100%;
  display: block;
}

/* Banner 右上角状态标签 */
.card-banner .status-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  display: inline-flex;
  align-items: center;
  padding: 8rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  z-index: 10;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.15);
}

.status-tag-icon {
  width: 26rpx;
  height: 26rpx;
  margin-right: 6rpx;
  flex-shrink: 0;
}

/* 状态颜色变体 */
.card-banner .status-upcoming {
  background: rgba(64, 150, 255, 0.95);
  color: #FFFFFF;
}

.card-banner .status-ongoing {
  background: rgba(82, 196, 26, 0.95);
  color: #FFFFFF;
}

.card-banner .status-ended {
  background: rgba(130, 130, 130, 0.9);
  color: #FFFFFF;
}

/* 状态标签内图标适配白色文字 */
.card-banner .status-tag-icon {
  filter: brightness(0) invert(1);
}

/* 卡片信息区 */
.card-info {
  padding: 24rpx 28rpx 0;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1D2129;
  line-height: 1.4;
  margin-bottom: 20rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 信息行 */
.info-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}

.info-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  opacity: 0.7;
}

.info-text {
  font-size: 26rpx;
  color: #4E5969;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 卡片底部操作按钮 */
.card-actions {
  padding: 20rpx 28rpx 24rpx;
}

.btn-primary-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 76rpx;
  background: #4096FF;
  border-radius: 38rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
  transition: background 0.2s;
}

.btn-primary-action:active {
  background: #1677FF;
}

/* ========== 加载状态 ========== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #E8F2FF;
  border-top-color: #4096FF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #86909C;
}

/* ========== 轮播图 ========== */
.swiper-banner {
  width: 94%;
  margin: 25rpx 3% 24rpx;
  height: 320rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.swiper-img {
  width: 100%;
  height: 100%;
  display: block;
}

.swiper-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 24rpx 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: linear-gradient(to top, rgba(0,0,0,0.5), transparent);
}

/* ========== 搜索框 ========== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  height: 72rpx;
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 0 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.search-icon-text {
  font-size: 28rpx;
  margin-right: 10rpx;
  opacity: 0.6;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1D2129;
}

.search-clear {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E0E3E8;
  border-radius: 50%;
  font-size: 22rpx;
  color: #FFFFFF;
  margin-left: 8rpx;
}

.search-btn {
  height: 72rpx;
  padding: 0 28rpx;
  background: #4096FF;
  border-radius: 36rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s;
}

.search-btn:active {
  background: #1677FF;
}

/* ========== 分类标签栏 ========== */
.category-bar {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.category-item {
  display: inline-block;
  padding: 10rpx 24rpx;
  margin-right: 16rpx;
  background: #FFFFFF;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #4E5969;
  transition: all 0.2s;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.category-item:last-child {
  margin-right: 0;
}

.category-active {
  background: #4096FF;
  color: #FFFFFF;
  font-weight: 600;
}

/* ========== 区块标题 ========== */
.section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1D2129;
}

.section-sub {
  font-size: 24rpx;
  color: #86909C;
}

.list-section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}

.filter-tag {
  font-size: 24rpx;
  color: #4096FF;
  background: #E8F2FF;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ========== 热门活动 ========== */
.hot-section {
  margin-bottom: 24rpx;
}

.hot-scroll {
  white-space: nowrap;
}

.hot-card {
  display: inline-block;
  width: 400rpx;
  margin-right: 20rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  transition: transform 0.2s;
}

.hot-card:active {
  transform: scale(0.98);
}

.hot-card:last-child {
  margin-right: 0;
}

.hot-img {
  width: 100%;
  height: 180rpx;
  display: block;
}

.hot-info {
  padding: 16rpx 20rpx 20rpx;
}

.hot-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1D2129;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-meta {
  display: block;
  font-size: 22rpx;
  color: #86909C;
  margin-bottom: 10rpx;
}

.hot-count {
  display: flex;
  align-items: baseline;
}

.hot-count-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #E53E3E;
  margin-right: 6rpx;
}

.hot-count-text {
  font-size: 22rpx;
  color: #86909C;
}

/* ========== 卡片分类标签 ========== */
.category-tag {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  padding: 6rpx 14rpx;
  background: rgba(0,0,0,0.55);
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  z-index: 10;
}

/* ========== 加载更多 ========== */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-light);
  font-size: 24rpx;
}

.all-loaded {
  color: var(--text-light);
}

.empty-sub {
  font-size: 26rpx;
  color: #4096FF;
  margin-top: 12rpx;
}
