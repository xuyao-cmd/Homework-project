<!--pages/admin/feedback.wxml - 意见反馈管理-->
<view class="page-container">
  <!-- 顶部统计 -->
  <view class="stats-bar">
    <view class="stat-card stat-total" data-filter="all" bindtap="switchFilter">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">全部反馈</text>
    </view>
    <view class="stat-card stat-pending" data-filter="pending" bindtap="switchFilter">
      <text class="stat-num">{{pendingCount}}</text>
      <text class="stat-label">待处理</text>
    </view>
    <view class="stat-card stat-done" data-filter="resolved" bindtap="switchFilter">
      <text class="stat-num">{{resolvedCount}}</text>
      <text class="stat-label">已处理</text>
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{noData}}" class="empty-wrap">
    <text class="empty-icon">🎉</text>
    <text class="empty-title">暂无反馈</text>
    <text class="empty-sub">一切运行良好</text>
  </view>

  <!-- 数据区域：筛选标签 + 列表 -->
  <block wx:else>
    <!-- 筛选标签 -->
    <view class="filter-tabs">
      <view class="filter-tab {{currentFilter === 'all' ? 'filter-active' : ''}}" data-filter="all" bindtap="switchFilter">
        全部
      </view>
      <view class="filter-tab {{currentFilter === 'pending' ? 'filter-active' : ''}}" data-filter="pending" bindtap="switchFilter">
        待处理
      </view>
      <view class="filter-tab {{currentFilter === 'resolved' ? 'filter-active' : ''}}" data-filter="resolved" bindtap="switchFilter">
        已处理
      </view>
    </view>

    <!-- 筛选后空状态 -->
    <view wx:if="{{filteredList.length === 0}}" class="empty-wrap small">
      <text class="empty-title">{{currentFilter === 'pending' ? '没有待处理的反馈' : currentFilter === 'resolved' ? '没有已处理的反馈' : '暂无反馈'}}</text>
    </view>

    <!-- 反馈列表 -->
    <view wx:else class="feedback-list">
      <view class="fb-card {{item.status === 'pending' ? 'fb-pending' : 'fb-resolved'}}" wx:for="{{filteredList}}" wx:key="_id">
        <!-- 左侧状态条 -->
        <view class="fb-stripe"></view>

        <!-- 右侧内容区 -->
        <view class="fb-body">
          <!-- 头部：类型 + 状态 + 时间 -->
          <view class="fb-top-row">
            <view class="fb-type-tag">
              <text wx:if="{{item.type === '功能建议'}}">💡</text>
              <text wx:elif="{{item.type === 'BUG反馈'}}">🐛</text>
              <text wx:elif="{{item.type === '体验问题'}}">😕</text>
              <text wx:else>📝</text>
              <text>{{item.type}}</text>
            </view>
            <view class="fb-status-tag {{item.status}}">
              <view class="fb-status-dot"></view>
              <text>{{item.statusText}}</text>
            </view>
            <text class="fb-time">{{item.createTimeDisplay}}</text>
          </view>

          <!-- 反馈内容 -->
          <view class="fb-content">
            <text>{{item.content}}</text>
          </view>

          <!-- 底部信息与操作 -->
          <view class="fb-bottom-row">
            <text class="fb-contact" wx:if="{{item.contact}}">
              <text class="fb-contact-icon">📞</text> {{item.contact}}
            </text>
            <view class="fb-spacer"></view>
            <view class="fb-btn-resolve" wx:if="{{item.status === 'pending'}}" data-id="{{item._id}}" bindtap="resolveFeedback">
              <text class="fb-btn-icon">✅</text>
              <text>标记已处理</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
